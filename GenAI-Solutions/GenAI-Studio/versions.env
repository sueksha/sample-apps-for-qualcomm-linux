# -----------------------------------------------------------------------------
# GenAI Studio canonical version manifest
#
# Usage:
#   set -a
#   source ./versions.env
#   set +a
#
# Keep this file limited to version/hint values. Host/model path overrides
# remain in .env / .env.example.
# -----------------------------------------------------------------------------

# Canonical QAIRT release baseline for this repository.
QAIRT_VERSION=2.45.0.260326

# Canonical flat runtime library bundle path on target.
QAIRT_FLAT_LIB_DIR=/opt/qairt/current/qairt_245_flat_libs

# Per-service runtime hint defaults used by docker-compose and run scripts.
TG_QAIRT_VERSION_HINT="build=2.45.0.260326;runtime=/opt/qairt/current/qairt_245_flat_libs"
I2T_QAIRT_VERSION_HINT="build=2.45.0.260326;runtime=/opt/qairt/current/qairt_245_flat_libs"
IMG_QAIRT_VERSION_HINT="runtime=2.45.0.260326"
STT_QAIRT_VERSION_HINT="runtime=2.45.0.260326"
